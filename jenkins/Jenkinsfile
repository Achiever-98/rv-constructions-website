pipeline {
    agent any

    environment {
        SCANNER_HOME = tool 'SonarScanner'
    }

    stages {
        stage('Print Workspace') {
            steps {
                sh '''
                    echo "Current Directory:"
                    pwd

                    echo ""
                    echo "Workspace Files:"
                    ls -la

                    echo ""
                    echo "App Folder:"
                    ls -la app
                '''
            }
        }

        stage('HTML Validation') {
            steps {
                sh '''
                htmlhint app/*.html --config lint/.htmlhintrc
                '''
            }
        }

        stage('CSS Validation') {
            steps {
                script {
                    def status = sh(
                script: '''
                    stylelint app/css/style.css \
                    --fix \
                    --config lint/.stylelintrc.json
                ''',
                returnStatus: true
            )

                    if (status != 0) {
                        echo 'Stylelint found issues. Continuing pipeline...'
                    }
                }
            }
        }

        stage('JavaScript Validation') {
            steps {
                sh '''
                    eslint app/js/*.js \
                    --config lint/.eslintrc.json || true
                '''
            }
        }

        stage('SonarQube Analysis') {
            steps {
                withSonarQubeEnv('SonarQube') {
                    sh '''
                        ${SCANNER_HOME}/bin/sonar-scanner \
                        -Dproject.settings=sonar/sonar-project.properties
                        '''
                }
            }
        }

        stage('Quality Gate') {
            steps {
                timeout(time: 5, unit: 'MINUTES') {
                    waitForQualityGate abortPipeline: true
                }
            }
        }

        stage('Docker Debug') {
            steps {
                sh '''
                echo "Current User:"
                whoami

                echo ""
                id

                echo ""
                ls -l /var/run/docker.sock

                echo ""
                docker version || true

                echo ""
                docker ps || true
            '''
            }
        }

        stage('Build Docker Image') {
            steps {
                sh '''
                    docker build \
                    -f docker/Dockerfile \
                    -t rv-constructions:${BUILD_NUMBER} .
                '''
            }
        }

        stage('Run Docker Container') {
            steps {
                sh '''
                    docker rm -f rv-constructions || true

                    docker run -d \
                    --name rv-constructions \
                    -p 8082:80 \
                    rv-constructions:${BUILD_NUMBER}
                '''
            }
        }
    }
}
